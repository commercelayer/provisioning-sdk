{
  "name": "@commercelayer/provisioning-sdk",
  "version": "2.10.2",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.mjs",
  "scripts": {
    "clean": "rm -rf ./.nyc_output ./node_modules/.cache ./coverage",
    "build": "tsup",
    "generate": "tsx gen/generator.ts",
    "generate-local": "pnpm generate --local",
    "lint": "biome check --enforce-assist=true",
    "check": "biome check --enforce-assist=true --write",
    "semantic-release": "semantic-release",
    "test": "vitest",
    "test-local": "tsx test/spot.ts",
    "coverage": "vitest run --coverage",
    "release": "pnpm upgrade && pnpm lint && pnpm build && pnpm test"
  },
  "keywords": [
    "javascript",
    "ecommerce",
    "commercelayer",
    "sdk",
    "provisioning"
  ],
  "author": "Pierluigi Viti <pierluigi@commercelayer.io>",
  "license": "MIT",
  "description": "Commerce Layer Provisioning SDK",
  "files": [
    "lib/**/*"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commercelayer/js-auth": "^7.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "json-typescript": "^1.1.2",
    "jsonapi-typescript": "^0.1.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "repository": "github:commercelayer/provisioning-sdk",
  "bugs": "https://github.com/commercelayer/provisioning-sdk/issues",
  "publishConfig": {
    "access": "public"
  },
  "resolutions": {
    "ansi-regex": "5.0.1"
  }
}
